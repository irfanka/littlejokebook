---
interface Props {
  title?: string;
}

const { title = "Little Jokebook" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <nav class="nav">
      <a href="/" class="nav-logo">Little Jokebook</a>
      <div class="nav-links">
        <a href="/comedians" class="nav-link">Comedians</a>
      </div>
    </nav>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    /* Warm cinema darks */
    --bg-deep: #0a0a0a;
    --bg-surface: #141414;
    --bg-card: #1a1a1a;
    --bg-card-hover: #222;
    --border-subtle: rgba(255, 255, 255, 0.06);

    --text-bright: #f0f0f0;
    --text-normal: #b3b3b3;
    --text-dim: #6d6d6d;

    --accent-warm: #e5a00d;
    --accent-warm-dim: rgba(229, 160, 13, 0.35);

    /* Fonts */
    --font-display: "Bebas Neue", Impact, sans-serif;
    --font-body: "Inter", -apple-system, sans-serif;

    /* Spacing */
    --gutter: clamp(1rem, 3vw, 3rem);
    --row-gap: 2.5rem;

    /* Motion */
    --ease: cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    -webkit-font-smoothing: antialiased;
  }

  body {
    font-family: var(--font-body);
    background: var(--bg-deep);
    color: var(--text-normal);
    line-height: 1.5;
    overflow-x: hidden;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  @media (prefers-reduced-motion: reduce) {
    * { transition-duration: 0.01ms !important; }
  }
</style>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.9rem var(--gutter);
    background: linear-gradient(to bottom, rgba(0,0,0,0.85) 0%, transparent 100%);
    pointer-events: none;
  }
  .nav > * { pointer-events: auto; }

  .nav-logo {
    font-family: var(--font-display);
    font-size: 1.5rem;
    letter-spacing: 0.06em;
    color: var(--accent-warm);
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--text-normal);
    transition: color 0.2s;
  }
  .nav-link:hover {
    color: var(--text-bright);
  }
</style>
